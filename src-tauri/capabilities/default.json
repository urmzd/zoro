{
  "identifier": "default",
  "description": "Default capability set for Zoro",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "shell:default",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "searxng",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
